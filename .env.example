# AEOspy Configuration

# ─────────────────────────────────────────────────────────────────────────────
# 1. BRIGHT DATA (Required for web intelligence, scraping, and SERP)
# ─────────────────────────────────────────────────────────────────────────────
# Get these at: https://brightdata.com/
# This token gives access to Web Unlocker, SERP API, and Scraping Browser
BRIGHT_DATA_API_TOKEN=your_bright_data_api_token_here

# Zone configuration (Names of the zones you created in Bright Data dashboard)
BRIGHT_DATA_SERP_ZONE=serp_zone
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker
BRIGHT_DATA_BROWSER_ZONE=scraping_browser

# ─────────────────────────────────────────────────────────────────────────────
# 2. AI ENGINES (Required for synthesis and analysis)
# ─────────────────────────────────────────────────────────────────────────────
# AIML API Key (Used to access Gemini and other models via aimlapi.com)
AIML_API_KEY=your_aiml_api_key_here

# Anthropic API Key (Required for Claude 3.5 Sonnet synthesis and SSE streaming)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# 3. VOICE SYNTHESIS (Optional, for voice briefings)
# ─────────────────────────────────────────────────────────────────────────────
# Speechmatics API Key (For high-quality Text-to-Speech and STT)
SPEECHMATICS_API_KEY=your_speechmatics_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
# Local SQLite database path (No external DB needed)
DATABASE_URL=file:./sqlite.db
